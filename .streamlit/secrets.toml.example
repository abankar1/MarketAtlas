# Streamlit Community Cloud secrets template.
#
# This file is committed to the repo as documentation. The real secrets file
# (`secrets.toml`) is git-ignored — for local Streamlit dev create
# `.streamlit/secrets.toml` from this template, and on Streamlit Community
# Cloud paste the same TOML into the app's "Settings → Secrets" UI.
#
# Settings are loaded by src/config/settings.py in this priority order:
#   1. st.secrets        (this file / Streamlit Cloud UI)
#   2. environment vars  (GitHub Actions daily-update job)
#   3. src/config/configuration.json (local-dev fallback)
#
# Keys may be flat (top-level) or nested under `[market_atlas]`. Both work.

# --- Required -------------------------------------------------------------

# Postgres / Timescale Cloud connection string used by the dashboard and
# the daily-update job. Use the read-write user.
db_url = "postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Marketstack API access key — daily bars + historical backfill.
marketdata_token = "your-marketstack-key"

# --- Optional -------------------------------------------------------------

# Days of history to fetch on each incremental update. Default 1000.
# days = 1000

# Delay between Marketstack API calls (seconds). Default 0.2.
# api_sleep_seconds = 0.2

# Anthropic API key — powers the Ask AI tab (LLM-generated SQL) and the
# sector classifier in src/services/sector_classifier.py.
anthropic_api_key = "sk-ant-..."

# Claude model id used by the Ask tab. Default "claude-haiku-4-5".
# anthropic_model = "claude-haiku-4-5"

# Read-only Postgres connection string for the Ask tab. Strongly recommended
# whenever anthropic_api_key is set, so LLM-generated SQL cannot write or
# drop anything. Create a dedicated read-only role on Timescale Cloud and
# use its credentials here.
db_url_readonly = "postgresql://READONLY_USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Marketaux API key — per-symbol news headlines on the Stock Detail tab.
marketaux_token = "your-marketaux-key"
